{
  "entities": {
    "users": {
      "title": "User",
      "description": "User profile information and roles",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "role": { "type": "string", "enum": ["admin", "customer"] },
        "suspended": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "products": {
      "title": "Product",
      "description": "E-commerce product details",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "imageURL": { "type": "string", "format": "uri" },
        "stock": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "stock"]
    },
    "wishlists": {
      "title": "Wishlist",
      "description": "User's saved products",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "productIds": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["userId", "productIds"]
    },
    "orders": {
      "title": "Order",
      "description": "Customer order details and tracking",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array", "items": { "type": "object" } },
        "total": { "type": "number" },
        "discount": { "type": "number" },
        "promoCode": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered"] },
        "trackingNumber": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "total", "status"]
    },
    "reviews": {
      "title": "Review",
      "description": "Product reviews and ratings",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "helpfulCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "userId", "rating", "comment"]
    },
    "carts": {
      "title": "Cart",
      "description": "Shopping cart for a user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array", "items": { 
          "type": "object",
          "properties": {
            "productId": { "type": "string" },
            "quantity": { "type": "number" }
          }
        } }
      },
      "required": ["userId", "items"]
    },
    "settings": {
      "title": "Settings",
      "description": "Global website settings",
      "type": "object",
      "properties": {
        "backgroundImageUrl": { "type": "string", "format": "uri" },
        "backgroundTheme": { "type": "string", "enum": ["default", "gold"] }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "User profiles"
    },
    "/products/{productId}": {
      "schema": "products",
      "description": "Available products"
    },
    "/wishlists/{userId}": {
      "schema": "wishlists",
      "description": "User wishlists"
    },
    "/orders/{orderId}": {
      "schema": "orders",
      "description": "Customer orders"
    },
    "/reviews/{reviewId}": {
      "schema": "reviews",
      "description": "Product reviews"
    },
    "/carts/{userId}": {
      "schema": "carts",
      "description": "User shopping carts"
    },
    "/settings/{document}": {
      "schema": "settings",
      "description": "Global settings documents"
    }
  }
}
